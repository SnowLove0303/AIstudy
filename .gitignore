# 忽略临时文件
.tmp/
*.log
.env
.env.*

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略 IDE 配置
.vscode/
.idea/

# Ignore generated dependencies and build outputs
node_modules/
dist/
dist-electron/
release/
release-fixed/
release-*/
index-*.js

# Ignore agent/tool scratch directories
.claude/
.claude-content-sandbox/
.omx/

# Ignore generated runtime caches and local probes
__pycache__/
*.pyc
tools/*-cdp-test.mjs
tools/knowledge-format-probe.html

# 保留所有文件（使用 Git LFS 管理大文件）
