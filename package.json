{
  "name": "aistudy",
  "version": "1.2.147",
  "description": "AIstudy desktop learning system shell.",
  "author": "SnowLove0303",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "ai:daily": "powershell -ExecutionPolicy Bypass -File scripts/ai-daily-workflow.ps1",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win nsis",
    "lint": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "code:lock": "powershell -ExecutionPolicy Bypass -File scripts/code-lock.ps1 -Action lock",
    "code:unlock": "powershell -ExecutionPolicy Bypass -File scripts/code-lock.ps1 -Action unlock",
    "code:lock:status": "powershell -ExecutionPolicy Bypass -File scripts/code-lock.ps1 -Action status",
    "claude:sandbox:prepare": "powershell -ExecutionPolicy Bypass -File scripts/prepare-claude-sandbox.ps1"
  },
  "dependencies": {
    "@hufe921/canvas-editor": "^0.9.135",
    "lucide-react": "^0.561.0",
    "mind-elixir": "^5.12.2",
    "mysql2": "^3.22.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.snowlove0303.aistudy",
    "productName": "AIstudy",
    "executableName": "AIstudy",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "docs/**/*",
      "mcp/**/*",
      "scripts/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AIstudy",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  }
}
